    "force-clean": "node scripts/force-clean.js",
    "dev:clean": "node scripts/clean-build.js && npm run prepare:dev && next dev -p 3000",
    "dev:force": "node scripts/force-clean.js && npm run prepare:dev && next dev -p 3000",
    "dev:fix": "node scripts/clean-build.js && npm run prepare:dev && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint"
  },
  "dependencies": {
